// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/**
 * Categorías para los contactos rápidos guardados por la IA o por el usuario.
 */
enum ContactCategory {
  FAMILY
  FRIEND
  WORK
  OTHER
}

model User {
  id                     String               @id @default(cuid())
  email                  String               @unique
  passwordHash           String
  name                   String?
  role                   Role                 @default(USER)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  /**
   * Token público (random URL-safe) usado para suscribir el calendario por
   * `webcal://` o descargar el .ics sin sesión. Se puede regenerar desde
   * Ajustes para invalidar suscripciones antiguas.
   */
  calendarFeedToken      String?              @unique
  events                 Event[]
  friendRequestsSent     FriendRequest[]      @relation("FriendRequestFrom")
  friendRequestsReceived FriendRequest[]      @relation("FriendRequestTo")
  adminNotes             AdminNote[]
  contacts               Contact[]
  passwordResetTokens    PasswordResetToken[]
}

/**
 * Códigos de un solo uso para «Olvidé mi contraseña». Se guarda el hash
 * del código (no el texto), expira en pocos minutos y queda inutilizable
 * tras consumirse o tras varios intentos fallidos.
 */
model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  /**
   * Hash bcrypt del código numérico de 6 dígitos enviado por email.
   */
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  /**
   * Conteo de intentos fallidos contra este token (bloqueo por fuerza bruta).
   */
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

/**
 * Notas Markdown gestionadas por administradores (sección /notas).
 */
model AdminNote {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model FriendRequest {
  id         String              @id @default(cuid())
  fromUserId String
  toUserId   String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  fromUser User @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

model Event {
  id                  String    @id @default(cuid())
  userId              String
  title               String
  description         String?
  location            String?
  startAt             DateTime
  endAt               DateTime
  color               String    @default("bg-blue-500")
  attendees           String[]  @default([])
  /**
   * Usuarios amigos incluidos en el evento (solo IDs de amistad aceptada).
   */
  participantUserIds  String[]  @default([])
  organizer           String?
  /**
   * Si ya se envió el recordatorio por correo el día del evento (cron).
   */
  reminderEmailSentAt DateTime?
  /**
   * Aviso "X minutos antes" configurable por el usuario (en minutos). Null = sin
   * recordatorio adicional al del día. Valores típicos: 5, 15, 30, 60, 120, 1440.
   */
  reminderMinutesBefore     Int?
  /**
   * Si ya se envió el recordatorio "X minutos antes" para este evento. Evita
   * dobles envíos cuando el cron corre cada 5 minutos.
   */
  reminderUpcomingSentAt    DateTime?
  /**
   * Si es false, no se envían correos de recordatorio (ni el del día a las 8:00
   * ni el aviso "X minutos antes"). El usuario puede volver a activarlos.
   */
  emailRemindersEnabled     Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
  @@index([reminderUpcomingSentAt, startAt])
}

/**
 * Contactos rápidos por usuario. Usado por la IA para inferir el calendario
 * (lane) cuando un evento menciona a una persona conocida (p. ej. «cumpleaños
 * de Benjamin» → Familia). Se sugieren al usuario para guardarse al vuelo.
 */
model Contact {
  id             String          @id @default(cuid())
  userId         String
  name           String
  /**
   * Versión normalizada (lowercase, sin acentos, espacios colapsados) para búsqueda.
   */
  normalizedName String
  category       ContactCategory
  /**
   * Relación opcional libre escrita por el usuario o sugerida por la IA («hermano», «compañero», «amiga»).
   */
  relation       String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId])
}
