DATABASE_URL="postgresql://calendar_user:calendar_password@localhost:5432/calendar_app?schema=public"
NEXTAUTH_SECRET="replace_with_a_long_random_secret"
OPENAI_API_KEY="replace_with_openai_key"

# Resend (correos: confirmación de eventos, recordatorios, amigos)
RESEND_API_KEY="re_xxxxxxxx"
# Dominio verificado en Resend, p. ej. "Calendario <notificaciones@tudominio.com>"
RESEND_FROM_EMAIL=""

# Opcional: enlace en el pie de los correos
PUBLIC_APP_URL="https://tu-dominio.com"

# Cron de recordatorios (GET /api/cron/event-reminders con Authorization: Bearer ...)
CRON_SECRET="replace_with_a_long_random_secret"

# Zona horaria para “hoy” en recordatorios (por defecto Europe/Madrid)
EVENT_TIMEZONE="Europe/Madrid"
